[Unit]
Description=Naozhi - Claude Code IM Gateway
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
# TODO: Change User, WorkingDirectory, and ExecStart paths to match your deployment
User=ec2-user
WorkingDirectory=/home/ec2-user/naozhi
ExecStart=/home/ec2-user/naozhi/bin/naozhi --config /home/ec2-user/naozhi/config.yaml
Restart=always
RestartSec=5

# Shim process survival: only kill main process on stop, never SIGKILL the cgroup.
# Shims are moved to /sys/fs/cgroup/naozhi-shims/ and must survive service restarts.
KillMode=process
SendSIGKILL=no
TimeoutStopSec=5

# Runtime environment
Environment=HOME=/home/ec2-user
Environment=PATH=/home/ec2-user/.local/bin:/home/ec2-user/.nvm/versions/node/v22.22.1/bin:/usr/local/bin:/usr/bin:/bin

# Bedrock auth (direct, IAM role, no proxy)
Environment=CLAUDE_CODE_USE_BEDROCK=1
Environment=AWS_REGION=ap-northeast-1
Environment=ANTHROPIC_DEFAULT_SONNET_MODEL=global.anthropic.claude-sonnet-4-6[1m]
Environment=ANTHROPIC_DEFAULT_OPUS_MODEL=global.anthropic.claude-opus-4-6-v1[1m]
Environment=ANTHROPIC_DEFAULT_HAIKU_MODEL=global.anthropic.claude-haiku-4-5-20251001-v1:0
Environment=ANTHROPIC_SMALL_FAST_MODEL=global.anthropic.claude-haiku-4-5-20251001-v1:0
Environment=ANTHROPIC_MODEL=global.anthropic.claude-opus-4-6-v1[1m]
Environment=CLAUDE_CODE_MAX_OUTPUT_TOKENS=128000

# Feishu credentials (create with deploy/setup-env.sh)
EnvironmentFile=-/home/ec2-user/.naozhi/env

[Install]
WantedBy=multi-user.target
